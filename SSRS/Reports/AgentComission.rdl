    <DataSet Name="Agent">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT CAST(NULL AS INT) AS AgentID, '(All Agents)' AS AgentName
UNION ALL
SELECT AgentID, FirstName + ' ' + LastName AS AgentName
FROM SalesAgent
ORDER BY AgentName</CommandText>
      </Query>
      <Fields>
        <Field Name="AgentID">
          <DataField>AgentID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="AgentName">
          <DataField>AgentName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
